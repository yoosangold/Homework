generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// 用户表
model User {
  id                  String          @id @default(cuid())
  email               String          @unique
  phone               String          @unique
  name                String
  password            String
  role                Role            @default(STUDENT)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  assignments         Assignment[]    @relation("TeacherAssignments")
  classStudents       ClassStudent[]
  classTeachers       ClassTeacher[]
  correctionsReviewer Correction[]    @relation("CorrectionReviewer")
  correctionsStudent  Correction[]    @relation("CorrectionStudent")
  wrongQuestions      WrongQuestion[]

  @@index([email])
  @@index([role])
}

/// 班级表
model Class {
  id            String         @id @default(cuid())
  name          String         @unique
  grade         Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  classStudents ClassStudent[]
  classTeachers ClassTeacher[]

  @@index([grade])
}

/// 班级 - 学生关联表（支持调班）
model ClassStudent {
  id          String    @id @default(cuid())
  userId      String?   // 可选，如果学生后来注册了可以关联
  studentName String    // 学生姓名
  studentPhone String?  // 学生手机号（选填，用于邀请家长注册）
  classId     String
  enrolledAt  DateTime  @default(now())
  isActive    Boolean   @default(true)
  class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([classId])
  @@index([studentPhone])
}

/// 班级 - 老师关联表
model ClassTeacher {
  id         String   @id @default(cuid())
  userId     String
  classId    String
  role       String   @default("TEACHER")
  assignedAt DateTime @default(now())
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
  @@index([userId])
  @@index([classId])
}

/// 作业表
model Assignment {
  id          String       @id @default(cuid())
  title       String
  description String?
  subject     Subject
  teacherId   String
  classId     String?
  dueDate     DateTime
  images      String?
  studentName String?
  studentId   String?
  instruction String?
  status      String       @default("PENDING")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  teacher     User         @relation("TeacherAssignments", fields: [teacherId], references: [id])
  corrections Correction[]

  @@index([teacherId])
  @@index([subject])
  @@index([dueDate])
  @@index([status])
}

/// 批改记录表
model Correction {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  status       String     @default("PENDING")
  score        Int?
  feedback     String?
  correctedAt  DateTime?
  reviewedAt   DateTime?
  reviewerId   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  reviewer     User?      @relation("CorrectionReviewer", fields: [reviewerId], references: [id])
  student      User       @relation("CorrectionStudent", fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@index([status])
}

/// 知识点表（树形结构）
model KnowledgePoint {
  id             String           @id @default(cuid())
  name           String
  code           String           @unique
  subject        Subject
  parentId       String?
  depth          Int              @default(0)
  description    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  parent         KnowledgePoint?  @relation("KnowledgePointHierarchy", fields: [parentId], references: [id])
  children       KnowledgePoint[] @relation("KnowledgePointHierarchy")
  wrongQuestions WrongQuestion[]

  @@index([subject])
  @@index([parentId])
  @@index([code])
}

/// 错题表
model WrongQuestion {
  id               String         @id @default(cuid())
  studentId        String
  knowledgePointId String
  questionContent  String
  studentAnswer    String?
  correctAnswer    String
  errorType        String?
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  reviewPlans      ReviewPlan[]
  knowledgePoint   KnowledgePoint @relation(fields: [knowledgePointId], references: [id])
  student          User           @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([knowledgePointId])
}

/// 复习计划表（基于艾宾浩斯记忆曲线）
model ReviewPlan {
  id              String        @id @default(cuid())
  wrongQuestionId String
  studentId       String
  reviewCount     Int           @default(0)
  lastReviewedAt  DateTime?
  nextReviewAt    DateTime?
  isCompleted     Boolean       @default(false)
  completedAt     DateTime?
  masteryLevel    Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  wrongQuestion   WrongQuestion @relation(fields: [wrongQuestionId], references: [id], onDelete: Cascade)

  @@index([wrongQuestionId])
  @@index([studentId])
  @@index([nextReviewAt])
  @@index([isCompleted])
}

enum Role {
  ADMIN
  HEAD_TEACHER
  TEACHER
  PARENT
  STUDENT
}

enum Subject {
  MATH
  CHINESE
  ENGLISH
}
