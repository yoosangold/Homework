# 百度 OCR 配置（免费额度：每天 500 次）
# 获取方式：https://console.bce.baidu.com/ai/

# 1. 注册百度账号并登录百度智能云
# 2. 创建应用：https://console.bce.baidu.com/ai/#/ai/ocr/app/list
# 3. 创建后获取 App ID、API Key、Secret Key

BAIDU_OCR_APP_ID=你的 APP_ID
BAIDU_OCR_API_KEY=你的 API_KEY
BAIDU_OCR_SECRET_KEY=你的 SECRET_KEY

# NextAuth 配置
NEXTAUTH_SECRET="homework-correction-system-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# 数据库配置
DATABASE_URL="postgres://xxx:xxx@db.prisma.io:5432/postgres?sslmode=require"
DIRECT_URL="postgres://xxx:xxx@db.prisma.io:5432/postgres?sslmode=require"
